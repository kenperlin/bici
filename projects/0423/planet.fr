if (x*x+y*y>.85) discard;
float dz=sqrt(1.-x*x-y*y);
float s=.3*x+.3*y+.9*dz;
s*=s;s*=s;
float cR=cos(.2*time),
      sR=sin(.2*time),
      cV=cos(.1*time),
      sV=sin(.1*time);
vec3 P=vec3(cR*x+sR*dz+cV,y,
           -sR*x+cR*dz+sV);
float f,g=turbulence(P);
float d=1.-1.2*(x*x+y*y);
d=d>0.?.1+.05*g+.6*(.1+g)*s*s
      :max(0.,d+.1);
f=sin(4.*P.x+8.*g+#0)-.2;
f=f>0.?1.:1.-f*f*f;
f*=d>.1?1.:(g+5.)/3.;
rgb=vec3(d*f*f*.85,d*f,d*.7);
